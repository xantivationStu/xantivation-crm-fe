{
  "version": "1.0",
  "description": "Flow map defining the order and connection logic between sections",
  "_source_of_truth": "Derived from flow.follows/recommended_next in each definition.json. Do not modify this file directly.",

  "sections_order": [
    { "id": "navbar", "order_weight": 0, "required": true },
    { "id": "hero", "order_weight": 10, "required": true },
    { "id": "logo-bar", "order_weight": 20, "required": false },
    { "id": "features-grid", "order_weight": 30, "required": false, "note": "features-grid OR how-it-works, usually do not need both" },
    { "id": "how-it-works", "order_weight": 40, "required": false },
    { "id": "showcase", "order_weight": 45, "required": false },
    { "id": "stats-bar", "order_weight": 50, "required": false },
    { "id": "testimonials", "order_weight": 60, "required": false },
    { "id": "pricing", "order_weight": 70, "required": false },
    { "id": "blog", "order_weight": 75, "required": false },
    { "id": "faq", "order_weight": 80, "required": false },
    { "id": "cta-banner", "order_weight": 90, "required": true },
    { "id": "transition", "order_weight": 99, "required": false },
    { "id": "footer", "order_weight": 100, "required": true }
  ],

  "valid_connections": {
    "navbar": ["hero"],
    "hero": ["logo-bar", "features-grid", "how-it-works"],
    "logo-bar": ["features-grid", "how-it-works", "stats-bar"],
    "features-grid": ["how-it-works", "showcase", "stats-bar", "testimonials"],
    "how-it-works": ["showcase", "features-grid", "stats-bar", "testimonials"],
    "showcase": ["testimonials", "pricing", "stats-bar"],
    "stats-bar": ["testimonials", "features-grid", "pricing"],
    "testimonials": ["pricing", "cta-banner", "faq", "blog"],
    "pricing": ["faq", "cta-banner", "testimonials", "blog"],
    "blog": ["faq", "cta-banner", "footer"],
    "faq": ["cta-banner"],
    "cta-banner": ["footer"],
    "footer": []
  },

  "mutual_exclusions": [
    {
      "group": ["features-grid", "how-it-works"],
      "rule": "soft-exclusive",
      "note": "Both can be used but usually only one is needed. If using both: features-grid goes first, how-it-works goes second."
    }
  ],

  "narrative_flow": {
    "description": "Each section answers a user question along their journey",
    "journey": [
      { "section": "navbar", "user_question": "What page is this? Where am I?" },
      { "section": "hero", "user_question": "What does this product do? Does it solve my problem?" },
      { "section": "logo-bar", "user_question": "Who else is using it? Is it trustworthy?" },
      { "section": "features-grid", "user_question": "Specifically, what can it do for me?" },
      { "section": "how-it-works", "user_question": "How do I use it? Is it complicated?" },
      { "section": "showcase", "user_question": "What does it actually look like?" },
      { "section": "stats-bar", "user_question": "How many people are using it? What are the actual results?" },
      { "section": "testimonials", "user_question": "What do actual users say? What is their experience?" },
      { "section": "pricing", "user_question": "How much does it cost? Is there a plan that fits me?" },
      { "section": "blog", "user_question": "What are the latest news, updates, or educational resources?" },
      { "section": "faq", "user_question": "I still have questions about X, Y, Z..." },
      { "section": "cta-banner", "user_question": "How do I get started?" },
      { "section": "footer", "user_question": "Where can I find more information?" }
    ]
  }
}

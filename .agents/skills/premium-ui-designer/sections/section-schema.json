{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CMS Section Skill Definition Schema",
  "type": "object",
  "required": ["id", "name", "category", "order_weight", "reusability", "tags", "content", "layout_variants", "animations", "transition", "flow", "tech"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier of the section. E.g., 'hero', 'faq'."
    },
    "name": {
      "type": "string",
      "description": "Friendly name of the section displayed on the CMS."
    },
    "category": {
      "type": "string",
      "enum": ["navigation", "entry", "trust", "value", "proof", "conversion", "support", "exit", "utility"],
      "description": "Category group representing the role of the section."
    },
    "order_weight": {
      "type": "integer",
      "description": "Default sorting weight in the page flow."
    },
    "reusability": {
      "type": "string",
      "enum": ["high", "universal", "medium", "low"],
      "description": "Reusability level of the section."
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Search tags."
    },
    "content": {
      "type": "object",
      "required": ["slots"],
      "properties": {
        "slots": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "required", "type"],
            "properties": {
              "name": { "type": "string" },
              "required": { "type": "boolean" },
              "type": { "type": "string" },
              "notes": { "type": "string" }
            }
          }
        }
      }
    },
    "layout_variants": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "description"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "visual_specs": {
            "type": "object",
            "required": ["typography", "spacing", "colors", "layout"],
            "properties": {
              "typography": { "type": "string" },
              "spacing": { "type": "string" },
              "colors": { "type": "string" },
              "layout": { "type": "string" }
            }
          },
          "code_blueprint": {
            "type": "object",
            "properties": {
              "gsap_timeline": { "type": "string" },
              "scroll_trigger": { "type": "string" },
              "interactive_hover": { "type": "string" },
              "css_classes": { "type": "string" }
            }
          },
          "anti_patterns": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "animations": {
      "type": "object",
      "required": ["entrance", "scroll_parallax", "interactive", "decorative"],
      "properties": {
        "entrance": { "type": "object" },
        "scroll_parallax": { "type": "object" },
        "interactive": { "type": "object" },
        "decorative": { "type": "object" }
      }
    },
    "transition": {
      "type": "object",
      "required": ["in", "out"],
      "properties": {
        "in": {
          "type": "object",
          "required": ["type", "description"],
          "properties": {
            "type": { "type": "string" },
            "description": { "type": "string" }
          }
        },
        "out": {
          "type": "object",
          "required": ["type", "description"],
          "properties": {
            "type": { "type": "string" },
            "description": { "type": "string" }
          }
        }
      }
    },
    "flow": {
      "type": "object",
      "required": ["follows", "recommended_next", "optional", "required_in_template"],
      "properties": {
        "follows": { "type": "array", "items": { "type": "string" } },
        "recommended_next": { "type": "array", "items": { "type": "string" } },
        "optional": { "type": "boolean" },
        "required_in_template": { "type": "boolean" },
        "notes": { "type": "string" }
      }
    },
    "tech": {
      "type": "object",
      "required": ["animation_lib", "dependencies", "cms_fields"],
      "properties": {
        "animation_lib": { "type": "string" },
        "dependencies": { "type": "array", "items": { "type": "string" } },
        "cms_fields": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}

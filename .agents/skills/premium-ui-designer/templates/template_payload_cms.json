{
  "id": "payload-cms-landing-full",
  "name": "Payload CMS Landing Page — Full Template",
  "description": "Full landing page for Payload CMS. Retain 100% when the user wants the complete template.",
  "project_type": "saas-cms",
  "target_audience": "developers, agencies, content teams",

  "sections": [
    {
      "id": "navbar",
      "variant": "floating-capsule",
      "config": {
        "cta_button": true,
        "announcement_bar": true
      }
    },
    {
      "id": "hero",
      "variant": "cinematic-video-fullscreen",
      "config": {
        "badge": true,
        "trust_line": true,
        "media_type": "product-screenshot",
        "background": "gradient-orbs + grid-pattern"
      },
      "transition_out": "soft-edge"
    },
    {
      "id": "logo-bar",
      "variant": "marquee-scroll",
      "config": {
        "label": "Trusted by teams at",
        "logo_count": 8
      },
      "transition_in": "continuation",
      "transition_out": "clean-break"
    },
    {
      "id": "features-grid",
      "variant": "interactive-grid-slideshow",
      "config": {
        "feature_count": 6,
        "background": "bg-gray-50"
      },
      "transition_in": "background-change (white → gray-50)",
      "transition_out": "gradient-fade"
    },
    {
      "id": "showcase",
      "variant": "stacking-cards-sticky",
      "config": {
        "background": "bg-gray-950",
        "media_type": "screenshot + annotations",
        "callout_count": 4
      },
      "transition_in": "background-change (gray-50 → gray-950)",
      "transition_out": "gradient-fade"
    },
    {
      "id": "faq",
      "variant": "illustration-search-split",
      "config": {
        "question_count": 8,
        "background": "bg-gray-900"
      },
      "transition_in": "continuation (same dark theme)",
      "transition_out": "gradient-fade"
    },
    {
      "id": "cta-banner",
      "variant": "centered-gradient",
      "config": {
        "background": "gradient primary-to-dark",
        "trust_signals": ["No credit card required", "Free 14-day trial", "Cancel anytime"]
      },
      "transition_in": "strong-visual-break",
      "transition_out": "footer-blend"
    },
    {
      "id": "footer",
      "variant": "4-col-classic",
      "config": {
        "newsletter_form": true,
        "social_links": true,
        "background": "bg-gray-950"
      },
      "transition_in": "continuation (dark)"
    }
  ],

  "color_scheme": {
    "primary": "indigo-600",
    "background_light": "white / gray-50",
    "background_dark": "gray-950 / gray-900",
    "text_primary": "gray-900",
    "text_secondary": "gray-500"
  },

  "animation_strategy": {
    "library": "framer-motion",
    "global_principle": "Scroll-triggered entrance, subtle hover states, smooth transitions. No overdoing it.",
    "performance_budget": "Keep LCP < 2.5s — do not use heavy animations above-fold"
  }
}

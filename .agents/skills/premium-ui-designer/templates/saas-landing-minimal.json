{
  "id": "saas-landing-minimal",
  "name": "SaaS Landing — Minimal Template",
  "description": "Minimalist SaaS Landing page with essential marketing sections.",
  "project_type": "saas-minimal",
  "target_audience": "startups, early-stage SaaS, indie hackers",
  "sections": [
    {
      "id": "navbar",
      "variant": "minimal-trigger",
      "config": {
        "cta_button": true,
        "announcement_bar": false
      }
    },
    {
      "id": "hero",
      "variant": "3d-floating-centered",
      "config": {
        "badge": true,
        "trust_line": false,
        "media_type": "screenshot",
        "background": "grid-pattern"
      },
      "transition_out": "soft-edge"
    },
    {
      "id": "features-grid",
      "variant": "typographic-editorial-bento",
      "config": {
        "feature_count": 4,
        "background": "bg-gray-50"
      },
      "transition_in": "background-change",
      "transition_out": "gradient-fade"
    },
    {
      "id": "how-it-works",
      "variant": "interactive-ui-cards",
      "config": {
        "step_count": 3,
        "background": "white"
      },
      "transition_in": "continuation",
      "transition_out": "gradient-fade"
    },
    {
      "id": "testimonials",
      "variant": "infinite-marquee-reviews",
      "config": {
        "testimonial_count": 3,
        "background": "bg-gray-50"
      },
      "transition_in": "background-change",
      "transition_out": "gradient-fade"
    },
    {
      "id": "pricing",
      "variant": "3-tier-classic",
      "config": {
        "background": "white"
      },
      "transition_in": "continuation",
      "transition_out": "gradient-fade"
    },
    {
      "id": "cta-banner",
      "variant": "centered-gradient",
      "config": {
        "background": "gradient primary-to-dark",
        "trust_signals": ["No credit card required", "Free trial"]
      },
      "transition_in": "strong-visual-break",
      "transition_out": "footer-blend"
    },
    {
      "id": "footer",
      "variant": "4-col-classic",
      "config": {
        "newsletter_form": false,
        "social_links": true,
        "background": "bg-gray-950"
      },
      "transition_in": "continuation"
    }
  ],
  "color_scheme": {
    "preset": "emerald"
  },
  "animation_strategy": {
    "library": "framer-motion",
    "global_principle": "Clean, snappy Framer Motion transitions with simple staggers and hover actions.",
    "performance_budget": "LCP < 2.5s — above fold content displays static first, hydrating interactive elements below"
  }
}
